      <column caption='Avg KPT Min (tableau customer experience clean.csv)' datatype='real' name='[Avg_KPT_Min (tableau_customer_experience_clean.csv)]' role='measure' type='quantitative' />
      <column caption='Avg KPT Min' datatype='real' name='[Avg_KPT_Min]' role='measure' type='quantitative' />
      <column caption='Avg Order Value (tableau restaurant performance clean.csv)' datatype='real' name='[Avg_Order_Value (tableau_restaurant_performance_clean.csv)]' role='measure' type='quantitative' />
      <column caption='Avg Order Value' datatype='real' name='[Avg_Order_Value]' role='measure' type='quantitative' />
      <column caption='Avg Rating (tableau customer experience clean.csv)' datatype='real' name='[Avg_Rating (tableau_customer_experience_clean.csv)]' role='measure' type='quantitative' />
      <column caption='Avg Rating (tableau restaurant performance clean.csv)' datatype='real' name='[Avg_Rating (tableau_restaurant_performance_clean.csv)]' role='measure' type='quantitative' />
      <column caption='Avg Rating' datatype='real' name='[Avg_Rating]' role='measure' type='quantitative' />
      <column caption='Avg Rider Wait Min' datatype='real' name='[Avg_Rider_Wait_Min]' role='measure' type='quantitative' />
      <column caption='Success Rate %' datatype='real' default-format='p0.0%' name='[Calculation_1829305934354739200]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Order_Success])' />
      </column>
      <column caption='Complaint Rate %' datatype='real' default-format='p0.0%' name='[Calculation_1829305934354829313]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Has_Complaint])' />
      </column>
      <column caption='Average Order Value' datatype='real' default-format='c&quot;₹ &quot;#,##0,.00K;&quot;₹ &quot;-#,##0,.00K' name='[Calculation_1829305934355091459]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Total]) / COUNTD([Order ID])' />
      </column>
      <column caption='Average Rating (Non-Zero)' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[Calculation_1829305934355156996]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [Rating] &gt; 0 THEN [Rating] END)' />
      </column>
      <column caption='Cancellation/Rejection Rate %' datatype='real' name='[Calculation_1829305934355210245]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;IF [Order Status] = &quot;Cancelled&quot; OR [Order Status] = &quot;Rejected&quot; THEN 1 ELSE 0 END&#13;&#10;)' />
      </column>
      <column caption='Avg KPT' datatype='real' name='[Calculation_1829305934355283974]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([KPT duration (minutes)])' />
      </column>
      <column caption='revenue' datatype='real' default-format='c&quot;₹ &quot;#,##0,.00K;&quot;₹ &quot;-#,##0,.00K' name='[Calculation_1829305934355476487]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Total])' />
      </column>
      <column caption='topzone' datatype='string' name='[Calculation_1829305934370091022]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Total]) = WINDOW_MAX(SUM([Total]))&#13;&#10;THEN &quot;Top&quot;&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='setup' datatype='string' name='[Calculation_1829305934394503188]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Revenue]) &gt;= WINDOW_PERCENTILE(SUM([Revenue]), 0.8)&#13;&#10;THEN &quot;Top 20%&quot;&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='City (tableau executive summary clean.csv)' datatype='string' name='[City (tableau_executive_summary_clean.csv)]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
